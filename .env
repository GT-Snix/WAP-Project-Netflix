# VITE_ PREFIX EXPLAINED:
# Vite strips ALL .env variables from the client bundle by default to prevent
# accidental secret leaks. Only variables that start with VITE_ are injected
# into import.meta.env and become accessible in browser-side code.
# Never add a VITE_ prefix to real secrets (e.g. private keys, passwords) —
# they will be visible in your production JS bundle via DevTools.

# TMDB v3 API key — used by api.js (Row, etc.) and Hero.jsx
VITE_TMDB_API_KEY=b86ec5ac836f10c20669b952d3c123bf

# Convenience alias used by Hero.jsx (and the Hero's useFetch call)
VITE_TMDB_KEY=b86ec5ac836f10c20669b952d3c123bf
